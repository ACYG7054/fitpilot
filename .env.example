OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
OPENAI_BASE_URL=

FITPILOT_APP_NAME=FitPilot
FITPILOT_API_PREFIX=/api/v1
FITPILOT_ENVIRONMENT=dev
FITPILOT_LOG_LEVEL=INFO

FITPILOT_CHAT_MODEL=gpt-4.1-mini
FITPILOT_ROUTER_MODEL=gpt-4.1-mini
FITPILOT_REVIEWER_MODEL=gpt-4.1-mini
FITPILOT_EMBEDDING_MODEL=text-embedding-3-small
FITPILOT_OPENAI_TIMEOUT_SECONDS=60
FITPILOT_OPENAI_SDK_RETRIES=2

FITPILOT_MYSQL_DSN=mysql+aiomysql://root:password@127.0.0.1:3306/fitpilot?charset=utf8mb4
FITPILOT_MYSQL_ECHO=false

FITPILOT_CHROMA_PATH=./storage/chroma
FITPILOT_CHROMA_COLLECTION=fitpilot_knowledge
FITPILOT_RAG_TOP_K=5
FITPILOT_RAG_VECTOR_K=8
FITPILOT_RAG_KEYWORD_K=12
FITPILOT_RAG_KEYWORD_LIMIT_PER_TERM=6
FITPILOT_RAG_MAX_CONTEXT_CHARS=3200

FITPILOT_REACT_MAX_ROUNDS=3
FITPILOT_REVIEWER_MAX_ROUNDS=2
FITPILOT_SERVICE_RETRY_ATTEMPTS=3
FITPILOT_SERVICE_RETRY_BACKOFF_SECONDS=1.0

FITPILOT_MCP_PROTOCOL_VERSION=2025-06-18
FITPILOT_MCP_SERVER_NAME=fitpilot-gym-mcp
FITPILOT_MCP_TIMEOUT_SECONDS=10
